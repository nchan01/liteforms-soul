# ── Database (Supabase Postgres) ─────────────────────────────────────────────
# Get both strings from: Supabase dashboard → your project → Connect button
#
# Transaction pooler (port 6543) — used by the live app on every request
DATABASE_URL="postgres://prisma.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) — used only by `prisma db push` / migrations
DIRECT_URL="postgres://prisma.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ── File Storage (Supabase Storage, S3-compatible) ────────────────────────────
# Create a bucket called "liteforms-files" in Supabase Storage (set to public).
# Get access key + secret from: Supabase dashboard → Storage → S3 Access Keys
S3_ENDPOINT="https://[PROJECT-REF].supabase.co/storage/v1/s3"
S3_REGION="auto"
AWS_ACCESS_KEY_ID="[SUPABASE_STORAGE_ACCESS_KEY]"
AWS_SECRET_ACCESS_KEY="[SUPABASE_STORAGE_SECRET_KEY]"
S3_BUCKET_NAME="liteforms-files"
# Public base URL for the bucket (no trailing slash)
S3_PUBLIC_URL="https://[PROJECT-REF].supabase.co/storage/v1/object/public/liteforms-files"
# To migrate to AWS S3 later: remove S3_ENDPOINT + S3_PUBLIC_URL, swap credentials.

# ── Auth0 ─────────────────────────────────────────────────────────────────────
AUTH0_SECRET="[openssl rand -hex 32]"
AUTH0_BASE_URL="https://your-deployment.vercel.app"
AUTH0_ISSUER_BASE_URL="https://[YOUR-TENANT].auth0.com"
AUTH0_CLIENT_ID="[AUTH0_CLIENT_ID]"
AUTH0_CLIENT_SECRET="[AUTH0_CLIENT_SECRET]"
# Shared secret between Auth0 post-login Action and this server
HOOK_SECRET="[openssl rand -hex 32]"

# ── Anthropic (optional) ──────────────────────────────────────────────────────
# Enables the "Auto-generate from SOUL.md" button on the upload page
ANTHROPIC_API_KEY="sk-ant-..."
