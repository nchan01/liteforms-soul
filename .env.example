# Database (Neon Postgres — pooled connection for serverless)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/liteforms_soul?sslmode=require"
# Direct connection for Prisma migrations
DIRECT_URL="postgresql://USER:PASSWORD@HOST/liteforms_soul?sslmode=require"

# Auth0
AUTH0_SECRET="use [openssl rand -hex 32]"
AUTH0_BASE_URL="https://yourdomain.vercel.app"
AUTH0_ISSUER_BASE_URL="https://YOUR_DOMAIN.auth0.com"
AUTH0_CLIENT_ID="YOUR_AUTH0_CLIENT_ID"
AUTH0_CLIENT_SECRET="YOUR_AUTH0_CLIENT_SECRET"

# Internal hook secret (shared between Auth0 Action and this server)
HOOK_SECRET="use [openssl rand -hex 32]"

# Vercel Blob (auto-provisioned by Vercel — added to .env.local automatically)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Anthropic — enables AI metadata generation on upload
ANTHROPIC_API_KEY="sk-ant-..."
